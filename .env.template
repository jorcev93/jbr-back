# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password
DB_NAME=jardin_botanico

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION_DAYS=7

# App
PORT=3000
NODE_ENV=development

# Storage (local | cloudinary)
STORAGE_TYPE=local

# Cloudinary (requerido solo si STORAGE_TYPE=cloudinary)
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret
# CLOUDINARY_FOLDER=jbre

# Seed (opcional; valores por defecto: admin@jbre.local / Admin123!)
# SEED_ADMIN_EMAIL=admin@tu-dominio.local
# SEED_ADMIN_PASSWORD=Admin123!
# SEED_ADMIN_NOMBRE=Admin
# SEED_ADMIN_APELLIDO=Sistema

# ============================================
# CONFIGURACIÓN DE INTELIGENCIA ARTIFICIAL
# ============================================

# --- Proveedor Principal de Chat ---
# Opciones: azure | ollama | google
AI_PROVIDER=azure

# URL base del servicio de IA
# Azure: https://tu-recurso.openai.azure.com/openai/deployments/tu-deployment/
# Ollama: http://localhost:11434/v1
# Google: (no requiere URL, usa SDK)
AI_BASE_URL=https://tu-recurso.openai.azure.com/openai/deployments/gemma-3-4b/

# API Key del proveedor
# Azure: tu API key de Azure OpenAI
# Ollama: (dejar vacío, no requiere)
# Google: tu API key de Google AI Studio
AI_API_KEY=tu-api-key-aqui

# Nombre del modelo a usar
# Azure/Ollama: gemma-3-4b-it, gpt-4o, llama3, etc.
# Google: gemini-1.5-flash, gemini-1.5-pro
AI_MODEL_NAME=gemma-3-4b-it

# --- Proveedor de Fallback (respaldo) ---
# Habilitar fallback cuando el modelo principal no puede responder
FALLBACK_ENABLED=true

# Tipo de proveedor de fallback
FALLBACK_PROVIDER=google

# URL base del fallback (solo si es azure u ollama)
FALLBACK_BASE_URL=

# API Key del fallback
FALLBACK_API_KEY=tu-google-api-key

# Modelo del fallback
FALLBACK_MODEL_NAME=gemini-1.5-flash

# --- Proveedor de Embeddings (para RAG) ---
# Tipo de proveedor: azure | ollama | google
EMBEDDINGS_PROVIDER=azure

# URL base para embeddings
EMBEDDINGS_BASE_URL=https://tu-recurso.openai.azure.com/openai/deployments/text-embedding-3-small/

# API Key para embeddings
EMBEDDINGS_API_KEY=tu-api-key-aqui

# Modelo de embeddings
EMBEDDINGS_MODEL_NAME=text-embedding-3-small

# Dimensiones del vector (1536 para text-embedding-3-small)
EMBEDDINGS_DIMENSIONS=1536

# --- Chat Configuration ---
CHAT_MAX_MESSAGES_STORED=50
CHAT_CONTEXT_MESSAGES=10

